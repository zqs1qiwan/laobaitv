<!DOCTYPE html>
<html class="no-js" lang="en-US">
<head>
<title>CDN节点请求源服务器被阻断</title>
<link rel="icon" href="https://assets.rnmcnm.com/assets/img/cdnfly/favicon.ico" type="image/x-icon">
<script src="https://lf26-cdn-tos.bytecdntp.com/cdn/expire-1-M/jquery/3.6.0/jquery.min.js"></script>
<meta charset="UTF-8" />
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
<meta http-equiv="X-UA-Compatible" content="IE=Edge,chrome=1" />
<meta name="robots" content="noindex, nofollow" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<style>
:root {
    --primary-color: #4a90e2;
    --error-color: #e74c3c;
    --text-color: #2c3e50;
    --bg-color: #f5f6fa;
}

body, html {
    margin: 0;
    padding: 0;
    height: 100%;
    font-family: 'Segoe UI', Arial, sans-serif;
    background: var(--bg-color);
    color: var(--text-color);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    overflow-x: hidden;
}

/* ipxinxi 容器 */
.ipxinxi {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    box-shadow: 0 8px 32px rgba(31, 38, 135, 0.15);
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 15px 30px;
    border-radius: 12px;
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.18);
    z-index: 1000;
}

.ipxinxi:hover {
    transform: translateX(-50%) translateY(-2px);
    box-shadow: 0 12px 40px rgba(31, 38, 135, 0.2);
}

/* 图片容器 */
.images-container {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin: 40px 0;
    perspective: 1000px;
}

/* 图片样式和动画 */
.images-container img {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 图片尺寸设置 */
.电脑 { 
    width: 70px;
    height: auto;
}
.箭头_右 { 
    width: 40px;
    height: auto;
}
.SCDN { 
    width: 70px;
    height: auto;
}
.链接 {
    width: 40px;
    height: auto;
}
.叉 { 
    width: 25px;
    height: auto;
}
.服务器 { 
    width: 60px;
    height: auto;
}

@keyframes floatAnimation {
    0%, 100% { transform: translate3d(0, 0, 0) rotate(0deg); }
    25% { transform: translate3d(0, -10px, 5px) rotate(2deg); }
    75% { transform: translate3d(0, 10px, -5px) rotate(-2deg); }
}

@keyframes fadeInScale {
    from {
        opacity: 0;
        transform: scale(0.8) translateY(20px);
    }
    to {
        opacity: 1;
        transform: scale(1) translateY(0);
    }
}

.电脑, .服务器, .SCDN, .链接 {
    animation: fadeInScale 0.5s forwards, floatAnimation 6s ease-in-out infinite;
}

.电脑 {
    animation-delay: 0s, 0s; /* 默认延迟 */
}

.SCDN {
    animation-delay: 0s, -2s; /* SCDN的floatAnimation延迟-2s */
}

.链接 {
    animation-delay: 0s, -3s;
}


.服务器 {
    animation-delay: 0s, -4s; /* 服务器的floatAnimation延迟-4s */
}

.箭头_右 {
    animation: fadeInScale 0.5s forwards 0.3s;
    transform-origin: center;
    transition: transform 0.3s ease;
}

.箭头_右:hover {
    transform: scale(1.2);
}

.叉 {
    animation: fadeInScale 0.5s forwards 0.6s;
    transform-origin: center;
    transition: transform 0.3s ease;
}

.叉:hover {
    transform: rotate(180deg) scale(1.2);
}

/* 标题样式 */
h1 {
    font-weight: 600;
    font-size: 4rem;
    background: linear-gradient(135deg, var(--primary-color), var(--error-color));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin: 20px 0;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
    animation: fadeInScale 0.8s forwards;
}

/* 页脚样式 */
footer {
    position: fixed;
    bottom: 0;
    width: 100%;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    padding: 15px 0;
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease;
    display: flex;
    justify-content: center;
    align-items: center;
}

footer:hover {
    transform: translateY(-2px);
}

.left-content, .right-content {
    flex: 1;
    text-align: center;
    padding: 0 20px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
}

.left-content::after {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    height: 80%;
    width: 1px;
    background: linear-gradient(to bottom, transparent, var(--text-color), transparent);
}

h2 {
    font-weight: 600;
    color: var(--primary-color);
    margin: 0;
    font-size: 1.1rem;
}

p {
    margin: 0;
    color: var(--text-color);
    font-size: 1rem;
}

/* 响应式设计 */
@media (max-width: 768px) {
    h1 {
        font-size: 2.5rem;
    }
    
    .images-container {
        flex-wrap: wrap;
        gap: 15px;
    }
    
    .ipxinxi {
        width: 80%;
        font-size: 0.9rem;
    }
    
    footer {
        padding: 12px 0;
    }
    
    .left-content, .right-content {
        padding: 0 10px;
        font-size: 0.9rem;
    }
    
    h2 {
        font-size: 1rem;
    }
    
    p {
        font-size: 0.9rem;
    }

    /* 移动端按钮样式 */
    .help-button {
        padding: 4px 8px;
        font-size: 10px;
        border-radius: 3px 0 0 3px;
    }

    .help-button:hover {
        padding-right: 10px;
    }

    /* 移动端提示框样式 */
    .tooltip {
        right: 50px;
        padding: 3px 6px;
        font-size: 9px;
        max-width: 70px;
        border-radius: 3px;
    }

    .tooltip::after {
        border-width: 3px 0 3px 3px;
        right: -3px;
    }
}

/* 更小屏幕的特殊处理 */
@media (max-width: 480px) {
    .help-button {
        padding: 3px 6px;
        font-size: 9px;
    }

    .help-button:hover {
        padding-right: 8px;
    }

    .tooltip {
        right: 40px;
        padding: 2px 4px;
        font-size: 8px;
        max-width: 60px;
    }
}

/* 添加按钮和提示框样式 */
.help-button {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    background: linear-gradient(135deg, var(--primary-color), #2980b9);
    color: white;
    padding: 8px 15px;
    border: none;
    border-radius: 5px 0 0 5px;
    cursor: pointer;
    font-size: 13px;
    font-weight: bold;
    box-shadow: -2px 2px 10px rgba(0,0,0,0.2);
    transition: all 0.3s ease;
    z-index: 999;
    text-decoration: none;
}

.help-button:hover {
    padding-right: 18px;
    background: linear-gradient(135deg, #2980b9, var(--primary-color));
}

.tooltip {
    position: fixed;
    right: 100px;
    top: 50%;
    transform: translateY(-50%);
    background: white;
    padding: 8px 12px;
    border-radius: 5px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    font-size: 12px;
    color: var(--text-color);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    z-index: 998;
    max-width: 140px;
}

.tooltip::after {
    content: '';
    position: absolute;
    right: -8px;
    top: 50%;
    transform: translateY(-50%);
    border-width: 8px 0 8px 8px;
    border-style: solid;
    border-color: transparent transparent transparent white;
}

.tooltip.show {
    opacity: 1;
    visibility: visible;
    animation: pulse 1s infinite;
}

@keyframes pulse {
    0% { transform: translateY(-50%) scale(1); }
    50% { transform: translateY(-50%) scale(1.05); }
    100% { transform: translateY(-50%) scale(1); }
}
</style>

</head>
<body>
    <div class="ipxinxi" style="text-align: center;">
    <span class="inline-block md:block heading-ray-id font-mono text-15 lg:text-sm lg:leading-relaxed">您的IP: 51.8.152.229 &bull;<br></span>
    <span class="inline-block md:block heading-ray-id font-mono text-15 lg:text-sm lg:leading-relaxed">节点IP: 104.168.4.167<br></span>
</div>

<div class="images-container">
    <img src="https://assets.rnmcnm.com/assets/img/cdnfly/电脑.svg" class="电脑" alt="电脑">
    <img src="https://assets.rnmcnm.com/assets/img/cdnfly/箭头_右.svg" class="箭头_右" alt="箭头_右">
    <a href="https://www.cdn1.vip" target="_blank">
    <img src="https://assets.rnmcnm.com/assets/img/cdnfly/SCDN.svg" class="SCDN" alt="SCDN">
    </a>
    <img src="https://assets.rnmcnm.com/assets/img/cdnfly/%E9%93%BE%E6%8E%A5.svg" class="链接" alt="链接">
    <img src="https://assets.rnmcnm.com/assets/img/cdnfly/叉.svg" class="叉" alt="叉">
    <img src="https://assets.rnmcnm.com/assets/img/cdnfly/服务器.svg" class="服务器" alt="服务器">
</div>

<div class="center-container">
    <h1 class="inline-block md:block mr-2 md:mb-2 font-light text-60 md:text-3xl text-black-dark leading-tight">
       <span data-translate="error">Error</span>
       <span>502</span>
    </h1>
</div>

<footer>
    <div class="left-content">
        <h2>什么问题？</h2>
        <p>CDN节点请求源服务器被阻断！</p>
    </div>
    <div class="right-content">
        <h2>如何解决？</h2>
        <p>请检查该站点源服务器的回源端口能否访问或拦截了CDN节点！</p>
    </div>
</footer>

<a href="https://www.rnmcnm.com/archives/3479" class="help-button">疑难杂症</a>
<div class="tooltip">点"疑难杂症"查解决方法</div>

<script>
// 添加页面载入动画
document.addEventListener('DOMContentLoaded', function() {
    // 为所有图片添加渐入效果
    const images = document.querySelectorAll('.images-container img');
    images.forEach((img, index) => {
        setTimeout(() => {
            img.style.opacity = '1';
            img.style.transform = 'translateY(0)';
        }, index * 200);
    });

    // IP信息容器动画
    const ipxinxi = document.querySelector('.ipxinxi');
    ipxinxi.style.opacity = '0';
    ipxinxi.style.transform = 'translateX(-50%) translateY(-20px)';
    
    setTimeout(() => {
        ipxinxi.style.transition = 'all 0.5s ease';
        ipxinxi.style.opacity = '1';
        ipxinxi.style.transform = 'translateX(-50%) translateY(0)';
    }, 300);
});

// 添加鼠标移动视差效果
document.addEventListener('mousemove', function(e) {
    const images = document.querySelectorAll('.images-container img');
    const xAxis = (window.innerWidth / 2 - e.pageX) / 25;
    const yAxis = (window.innerHeight / 2 - e.pageY) / 25;
    
    images.forEach((img) => {
        img.style.transform = `translate(${xAxis}px, ${yAxis}px)`;
    });
});

// 添加提示框显示逻辑
function showTooltip() {
    const tooltip = document.querySelector('.tooltip');
    tooltip.classList.add('show');
    
    setTimeout(() => {
        tooltip.classList.remove('show');
    }, 3000); // 显示3秒后隐藏
}

// 每5秒显示一次提示
setInterval(showTooltip, 5000);

// 页面加载后先显示一次
setTimeout(showTooltip, 1000);
</script>
</body>
</html>


